  </div>
</section>

<footer><p>Harmonie Yacht × Robin Pailhes — Infrastructure IA © 2026</p></footer>

<script>
const reveals=document.querySelectorAll('.reveal');
const obs=new IntersectionObserver((entries)=>{entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*60);obs.unobserve(e.target)}})},{threshold:.12});
reveals.forEach(el=>obs.observe(el));
</script>
