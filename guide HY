          <li>Activité des conversations clients</li>
          <li>Envoi automatique sur Telegram</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- COMMENT ÇA MARCHE -->
<section style="background:var(--surface)">
  <div class="container">
    <div class="section-label reveal">Comment ça marche</div>
    <div class="section-title reveal">Le parcours d'un client, de A à Z</div>
